<h1 class="text-center mt-4">Create a Category</h1>

<div class="container mt-4">
 <%= render 'shared/errors', obj: @category %>

  <div class="row justify-content-center">
    <div class="col-8">

      <!-- 🔵 Card Box -->
      <div class="card bg-info text-white p-4 shadow">

        <%= form_with model: @category, data: { turbo: false } do |f| %>

          <!-- 📝 name  -->
          <div class="mb-3">
            <%= f.label :"category name", class: "form-label" %>
            <%= f.text_field :name,
                class: "form-control",
                placeholder: "Enter a name..." %>
          </div>

          <!-- 🚀 Submit -->
          <div class="text-center">
            <%= f.submit class: "btn btn-outline-light btn-lg" %>
          </div>

        <% end %>

      </div>

      <!-- 🔙 Cancel -->
      <div class="text-center mb-3">
        <%= link_to "[Cancel and return to articles]", articles_path, class: "text-decoration-none" %>
      </div>

    </div>
  </div>
</div>
                  